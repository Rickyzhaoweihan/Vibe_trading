# Copy to .env and fill in. .env is gitignored — never commit real values.
#   cp .env.example .env

# ============================= REQUIRED ======================================

# --- your brokerage account IDs (Robinhood) ---------------------------------
# Find them: in Claude Code (with the robinhood-trading MCP connected) ask
# "list my accounts", or see Robinhood app -> Account -> Investing -> Account number.
DESK_ACCOUNT=           # the advisory desk's real book (READ-ONLY — never traded)
BOT_ACCOUNT=            # only if you enable the OPTIONAL auto-trader (agentic account)

# --- LLM for the deep-research stack (bot/deepresearch.py) -------------------
# Cheapest good option: GLM 5.2 via OpenRouter (~$0.20/name researched).
# Alternatives: BOT_LLM_PROVIDER=anthropic with claude models (higher quality, ~3x cost).
BOT_LLM_PROVIDER=openrouter
BOT_DEEP_LLM=z-ai/glm-5.2
BOT_QUICK_LLM=z-ai/glm-5.2
OPENROUTER_API_KEY=     # https://openrouter.ai/settings/keys

# ============================= OPTIONAL ======================================

# --- alert routing (bot/notify.py) -------------------------------------------
# ALERT_CHANNEL picks the delivery path:
#   email    = Gmail SMTP ONLY (the full report arrives as one email, untruncated;
#              fails loudly rather than sending from the wrong account)
#   imessage = iMessage only (1800-char cap; long reports get chunked)
#   auto     = iMessage -> Mail.app -> SMTP fallback chain (default)
ALERT_CHANNEL=auto
ALERT_EMAIL=            # where email is DELIVERED
ALERT_IMESSAGE=         # your phone for iMessage alerts, e.g. +1XXXXXXXXXX
ALERT_GMAIL_USER=       # the SENDING Gmail account (create an App Password)
ALERT_GMAIL_APP_PASSWORD=   # 16-char App Password; spaces are stripped

# --- desk behavior -----------------------------------------------------------
DESK_LANG=en            # en = English notes; zh = translate to Simplified Chinese
#DESK_SNAP_EVERY=3      # intraday: re-snapshot your account every N monitor ticks (0=off)
#DESK_MCP_QUOTES=1      # 1 = broker real-time quotes via the MCP relay; 0 = yfinance only
#DESK_SCOUT_DISCOVER=1  # 1 = live market screens surface fresh idea candidates

# --- research cost knobs ------------------------------------------------------
#DESK_RESEARCH_MIN_SCORE=25   # priority a name needs to earn a deep-research run
#DESK_RESEARCH_MAX=8          # max deep-research runs per desk pass

# --- risk knobs ----------------------------------------------------------------
#DESK_DEFAULT_STOP_PCT=0.12   # fallback protective stop when research gives none
#DESK_BASE_HEDGE=0.05         # standing downside-hedge floor (fraction of equity; 0=reactive only)
#DESK_HEDGE_TICK=60           # monitor cadence (seconds) while a -3x inverse ETF is held
#DESK_HEDGE_REALTIME=1        # 1 = broker real-time quotes for the leveraged-hedge stop

# --- OPTIONAL auto-trader only (bot/run*.sh; off unless you schedule it) -------
PAPER_MODE=1            # 1 = paper (no real orders). Set 0 ONLY when you accept live trading.
ANTHROPIC_API_KEY=      # required ONLY by the auto-trader's router/reflection
                        # (the advisory desk never needs it — its claude -p relays
                        # use your Claude Code CLI login instead)
#BRAIN_MODEL=claude-sonnet-4-6   # model for the auto-trader's router/reflection
