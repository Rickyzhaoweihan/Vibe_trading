# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- LLM for the deep-research stack (bot/deepresearch.py) -------------------
# Default is Anthropic; set these to route the TradingAgents research elsewhere.
BOT_LLM_PROVIDER=openrouter
BOT_DEEP_LLM=z-ai/glm-5.2
BOT_QUICK_LLM=z-ai/glm-5.2
OPENROUTER_API_KEY=
# Only needed if BOT_LLM_PROVIDER=anthropic (the claude -p relays use the CLI login, not this):
ANTHROPIC_API_KEY=

# --- paper vs live ----------------------------------------------------------
PAPER_MODE=1

# --- your brokerage account IDs (Robinhood) ---------------------------------
BOT_ACCOUNT=            # the autonomous auto-trader's account
DESK_ACCOUNT=           # the advisory desk's real book (read-only)

# --- alert routing (bot/notify.py) ------------------------------------------
ALERT_EMAIL=
ALERT_IMESSAGE=         # e.g. +1XXXXXXXXXX
ALERT_GMAIL_USER=
ALERT_GMAIL_APP_PASSWORD=
