<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.rickyhan.desk.wrap</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/rickyhan/trading_agent/bot/desk/run_desk.sh</string>
    <string>wrap</string>
  </array>
  <!-- 16:30 ET: after the close + the after-hours earnings dust settles. -->
