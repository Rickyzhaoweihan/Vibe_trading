<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.rickyhan.desk.watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/rickyhan/trading_agent/bot/desk/run_desk.sh</string>
    <string>watchdog</string>
  </array>
  <!-- 09:15 ET: the 08:00 preopen note should have completed by now. If it
       didn't (machine asleep, plist unloaded, crash), alert. -->
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>15</integer></dict>
  <key>WorkingDirectory</key><string>/Users/rickyhan/trading_agent</string>
  <key>StandardOutPath</key><string>/Users/rickyhan/trading_agent/bot/logs/launchd.desk.watchdog.log</string>
  <key>StandardErrorPath</key><string>/Users/rickyhan/trading_agent/bot/logs/launchd.desk.watchdog.log</string>
  <key>RunAtLoad</key><false/>
</dict></plist>
